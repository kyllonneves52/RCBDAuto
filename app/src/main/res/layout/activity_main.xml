<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D0D0D">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ʟᴀᴄᴏsᴛᴇ Cerveces auto"
            android:textSize="22sp"
            android:textColor="#00FF88"
            android:textStyle="bold"
            android:gravity="center"
            android:letterSpacing="0.1"
            android:paddingBottom="20dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="STATUS DO SISTEMA"
            android:textSize="14sp"
            android:textColor="#00FF88"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="A verificar..."
            android:textSize="13sp"
            android:textColor="#CCCCCC"
            android:background="#1A1A1A"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MODO DE ENVIO"
            android:textSize="14sp"
            android:textColor="#00FF88"
            android:textStyle="bold"/>

        <Spinner
            android:id="@+id/spinnerApp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#1A1A1A"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ENVIAR TESTE"
            android:textSize="14sp"
            android:textColor="#00FF88"
            android:textStyle="bold"/>

        <EditText
            android:id="@+id/mb"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Quantidade MB"
            android:inputType="number"
            android:textColor="#FFFFFF"
            android:textColorHint="#555555"
            android:background="#1A1A1A"
            android:padding="12dp"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/numero"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Número cliente"
            android:inputType="phone"
            android:textColor="#FFFFFF"
            android:textColorHint="#555555"
            android:background="#1A1A1A"
            android:padding="12dp"
            android:layout_marginBottom="12dp"/>

        <Button
            android:id="@+id/enviar"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:text="ENVIAR TESTE"
            android:textColor="#000000"
            android:textStyle="bold"
            android:backgroundTint="#00FF88"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="FILA"
            android:textSize="14sp"
            android:textColor="#00FF88"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/fila"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pedidos: 0"
            android:textColor="#CCCCCC"
            android:background="#1A1A1A"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="LOG"
            android:textSize="14sp"
            android:textColor="#00FF88"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/log"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:text="RCBDAuto iniciado"
            android:textColor="#00FF88"
            android:textSize="11sp"
            android:background="#000000"
            android:padding="10dp"
            android:scrollbars="vertical"/>

        <Button
            android:id="@+id/atualizar"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:text="ATUALIZAR ESTADO"
            android:backgroundTint="#333333"
            android:textColor="#FFFFFF"
            android:layout_marginTop="12dp"/>

        <Button
            android:id="@+id/diagnostico"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:text="DIAGNÓSTICO"
            android:backgroundTint="#333333"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/permissoes"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:text="ABRIR PERMISSÕES"
            android:backgroundTint="#333333"
            android:textColor="#FFFFFF"/>

    </LinearLayout>
</ScrollView>